public class MissingElement
{
	public static void main(String[] args) {
	    int[] arr={1,2,3,5,6};
	    int j=0;
	    int n=arr.length+1;
	    int exp_sum=n*(n+1)/2;
	    int sum=0;
	    for (int i=0;i<n-1;i++){
	        sum+=arr[i];
	    }
	    int missing_number=exp_sum-sum;
	    System.out.println("Missing element is "+missing_number);
	}
}
