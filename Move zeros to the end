public class ZeroesToEnd
{
	public static void main(String[] args) {
	    int[] arr={0,0,3,5,12};
	    int j=0;
	    for (int i=1;i<arr.length;i++){
	        if (arr[i]!=0){
	            arr[j]=arr[i];
	            j++;
	        }
	    }
	    while (j<arr.length){
	        arr[j]=0;
	        j++;
	    }
	    System.out.println("Array after moving the zeroes to end:");
	    for (int num:arr){
	        System.out.print(num+" ");
	    }
	}
}
